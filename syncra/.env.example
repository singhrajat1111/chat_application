# ============================================
# Syncra Docker Compose Environment
# Copy this file to .env and fill in values
# ============================================

# Database
DB_PASSWORD=changeme_to_strong_password

# Redis
REDIS_PASSWORD=changeme_to_strong_password

# JWT - REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS)
CLIENT_URL=http://localhost

# Frontend build-time variables
# For same-origin deployment (nginx proxies /api to backend), use relative paths:
VITE_API_URL=/api
VITE_SOCKET_URL=
# For cross-origin deployment, use full URLs:
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_SOCKET_URL=https://api.yourdomain.com
